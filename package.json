{
	"name": "create-typescript-express",
	"version": "1.1.0",
	"description": "Create a lightweight Express 5 application with TypeScript, linting, tests, Docker, and CI.",
	"author": "BlackishGreen33 <s5460703@gmail.com>",
	"license": "MIT",
	"bin": {
		"create-typescript-express": "bin/create-typescript-express.js"
	},
	"files": [
		"bin",
		"template",
		"!template/node_modules",
		"!template/node_modules/**",
		"!template/dist",
		"!template/dist/**",
		"!template/.tmp",
		"!template/.tmp/**",
		"README.md",
		"README.zh-TW.md",
		"README.zh-CN.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=24",
		"npm": ">=10"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/BlackishGreen33/TypeScript-Express-Template.git"
	},
	"bugs": {
		"url": "https://github.com/BlackishGreen33/TypeScript-Express-Template/issues"
	},
	"homepage": "https://github.com/BlackishGreen33/TypeScript-Express-Template#readme",
	"keywords": [
		"create",
		"express",
		"expressjs",
		"typescript",
		"template",
		"boilerplate",
		"starter"
	],
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"commander": "^14.0.3",
		"picocolors": "^1.1.1"
	},
	"scripts": {
		"lint": "eslint .",
		"format": "prettier --write \"**/*.{js,mjs,json,md,yml,yaml,css,ts}\"",
		"format:check": "prettier --check \"**/*.{js,mjs,json,md,yml,yaml,css,ts}\"",
		"test": "node --test test/*.test.js",
		"test:template": "npm --prefix template ci && npm --prefix template run check",
		"test:smoke": "node test/smoke-create.js",
		"test:docker": "node test/docker-smoke.js",
		"pack:dry-run": "npm pack --dry-run",
		"audit": "npm audit --omit dev",
		"audit:template": "npm --prefix template audit --omit dev",
		"check": "npm run lint && npm run format:check && npm test && npm run test:template && npm run test:smoke && npm run pack:dry-run && npm run audit && npm run audit:template"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.2.1",
		"globals": "^17.5.0",
		"prettier": "^3.8.3"
	}
}
