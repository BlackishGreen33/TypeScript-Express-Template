{
	"compilerOptions": {
		"module": "NodeNext",
		"esModuleInterop": true,
		"target": "ES2023",
		"lib": ["ES2023"],
		"rootDir": "./",
		"outDir": "./dist",
		"strict": true,
		"moduleResolution": "NodeNext",
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
